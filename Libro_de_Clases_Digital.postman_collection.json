          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estudianteId\": 1,\n  \"valor\": 6.5\n}"
            },
            "url": "{{gateway}}/api/academica/nota/1"
          },
          "response": [
            {
              "name": "400 Bad Request - fuera de rango",
              "body": "{\n  \"mensaje\": \"La nota debe estar entre 1.0 y 7.0\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Asistencia - Registro",
      "item": [
        {
          "name": "Listar registros de asistencia",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{gateway}}/api/asistencia/asistencia"
          }
        },
