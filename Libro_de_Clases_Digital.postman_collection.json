{
  "info": {
    "name": "Libro de Clases Digital - Colegio Bernardo O'Higgins",
    "description": "Coleccion Postman del proyecto DSY1106. Todas las peticiones pasan por el API Gateway en el puerto 8080. Ejecutar primero Auth > Login para obtener el token JWT y guardarlo en la variable de coleccion 'token'.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "gateway", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "if (data.token) { pm.collectionVariables.set('token', data.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{gateway}}/auth/login"
          },
          "response": [
            {
              "name": "200 OK",
              "body": "{\n  \"token\": \"eyJhbGciOiJIUzI1NiJ9...\"\n}"
            },
            {
              "name": "401 Unauthorized",
              "body": "{\n  \"error\": \"Credenciales invalidas\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Gestion Academica - Curso",
      "item": [
        {
          "name": "Listar cursos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{gateway}}/api/academica/curso"
          }
        },
        {
          "name": "Obtener curso por id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{gateway}}/api/academica/curso/1"
          }
        },
        {
          "name": "Crear curso",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"1ro Medio A\",\n  \"nivel\": \"Ensenanza Media\",\n  \"anioLectivo\": 2026\n}"
            },
            "url": "{{gateway}}/api/academica/curso"
          },
          "response": [
            {
              "name": "200 OK",
              "body": "{\n  \"id\": 1,\n  \"nombre\": \"1ro Medio A\",\n  \"nivel\": \"Ensenanza Media\",\n  \"anioLectivo\": 2026,\n  \"asignaturas\": null\n}"
            }
          ]
        },
        {
          "name": "Actualizar curso",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"1ro Medio B\",\n  \"nivel\": \"Ensenanza Media\",\n  \"anioLectivo\": 2026\n}"
            },
            "url": "{{gateway}}/api/academica/curso/1"
          }
        },
        {
          "name": "Eliminar curso",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{gateway}}/api/academica/curso/1"
          }
        }
      ]
    },
    {
      "name": "Gestion Academica - Asignatura",
      "item": [
        {
          "name": "Listar asignaturas",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{gateway}}/api/academica/asignatura"
          }
        },
        {
          "name": "Obtener asignatura por id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{gateway}}/api/academica/asignatura/1"
          }
        },
        {
          "name": "Listar asignaturas por curso",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{gateway}}/api/academica/asignatura/curso/1"
          }
        },
        {
          "name": "Crear asignatura",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Ciencias\",\n  \"docente\": \"Prof. Anais\",\n  \"curso\": { \"id\": 1 }\n}"
            },
            "url": "{{gateway}}/api/academica/asignatura"
          },
          "response": [
            {
              "name": "200 OK",
              "body": "{\n  \"id\": 1,\n  \"nombre\": \"Ciencias\",\n  \"docente\": \"Prof. Anais\",\n  \"curso\": { \"id\": 1, \"nombre\": \"1ro Medio A\" }\n}"
            }
          ]
        },
        {
          "name": "Actualizar asignatura",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Matematicas\",\n  \"docente\": \"Prof. Jose\",\n  \"curso\": { \"id\": 1 }\n}"
            },
            "url": "{{gateway}}/api/academica/asignatura/1"
          }
        },
        {
          "name": "Eliminar asignatura",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{gateway}}/api/academica/asignatura/1"
          }
        }
      ]
    },
    {
