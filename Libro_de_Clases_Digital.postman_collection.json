            "url": "{{gateway}}/api/academica/evaluacion/1"
          }
        }
      ]
    },
    {
      "name": "Gestion Academica - Nota",
      "item": [
        {
          "name": "Listar notas",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{gateway}}/api/academica/nota"
          }
        },
